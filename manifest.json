{
  "manifest_version": 3,
  "name": "Instagram Aviation Manager",
  "version": "1.0.0",
  "description": "AI-powered Instagram manager for your aviation account, powered by Claude.",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "sidePanel",
    "alarms"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://api.anthropic.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/index.html"
  },

  "action": {
    "default_title": "Instagram Aviation Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
